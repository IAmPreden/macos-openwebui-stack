# Compose project
COMPOSE_PROJECT_NAME=macos-openwebui

# Host ports
OPENWEBUI_PORT=3000
SEARXNG_PORT=8888
FIRECRAWL_PORT=3002

# Image tags
OPENWEBUI_IMAGE_TAG=main
FIRECRAWL_IMAGE_TAG=latest
FIRECRAWL_PLAYWRIGHT_IMAGE_TAG=latest
FIRECRAWL_POSTGRES_IMAGE_TAG=latest

# Open WebUI
WEBUI_URL=http://localhost:3000
WEBUI_SECRET_KEY=CHANGE_ME_GENERATED_BY_BOOTSTRAP
AIOHTTP_CLIENT_TIMEOUT=600
ENABLE_RETRIEVAL_UNSCOPED_COLLECTIONS=true
BYPASS_RETRIEVAL_ACCESS_CONTROL=true

# LM Studio / OpenAI-compatible local inference
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_API_KEY=CHANGE_ME_GENERATED_BY_BOOTSTRAP
LM_STUDIO_EMBEDDING_MODEL=text-embedding-bge-m3
LM_STUDIO_RERANKER_MODEL=text-embedding-bge-reranker-v2-m3

# Self-hosted Firecrawl
FIRECRAWL_API_BASE_URL=http://firecrawl-api:3002
FIRECRAWL_API_KEY=CHANGE_ME_GENERATED_BY_BOOTSTRAP
BULL_AUTH_KEY=CHANGE_ME_GENERATED_BY_BOOTSTRAP

# Firecrawl Postgres
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_GENERATED_BY_BOOTSTRAP

# SearXNG
SEARXNG_SECRET_KEY=CHANGE_ME_GENERATED_BY_BOOTSTRAP

# Watchtower keeps the Open WebUI and SearXNG images current on Sunday at 03:00.
WATCHTOWER_SCHEDULE=0 0 3 * * 0
